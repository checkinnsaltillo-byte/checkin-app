# ===== Facturapi (existente) =====
FACTURAPI_SECRET_KEY=
CHECKIN_WEB_APP_URL=
PORT=8080

# ===== Breezeway (integración de alertas de aseo / estado) =====
# Credenciales de la API (NO las subas a git; este archivo es solo ejemplo).
BREEZEWAY_CLIENT_ID=
BREEZEWAY_CLIENT_SECRET=

# URL pública HTTPS de tu webhook (la que Breezeway llamará).
# Debe apuntar a /api/breezeway/webhook de este servidor desplegado.
BREEZEWAY_WEBHOOK_PUBLIC_URL=https://tu-dominio.com/api/breezeway/webhook

# Token secreto anti-spoofing: si lo defines, se exige ?token=... en el webhook
# (se añade automáticamente a la URL al suscribir). Usa un valor largo y aleatorio.
BREEZEWAY_WEBHOOK_TOKEN=

# Opcional: filtra qué tareas cuentan como "aseo" (substring del tipo/nombre).
# Ej: clean  -> sólo dispara alerta en tareas cuyo tipo contenga "clean".
BREEZEWAY_CLEANING_TYPE_FILTER=
